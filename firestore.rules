rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Estado principal de la plataforma
    match /quick_lastmile/{documentId} {
      allow read, write: if true;
    }
    // Medios (fotos/soportes) como documentos individuales — alternativa gratuita a Storage
    match /quick_media/{mediaId} {
      allow read, write: if true;
    }
  }
}
